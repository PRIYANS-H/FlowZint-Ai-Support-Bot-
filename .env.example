# Supabase PostgreSQL connection string (Session mode on port 5432)
# Format: postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres
SUPABASE_DB_URL=postgresql://postgres.xxxxxxxxxxxx:YOUR_PASSWORD@aws-0-ap-south-1.pooler.supabase.com:5432/postgres

# Groq API key — https://console.groq.com/keys
GROQ_API_KEY=gsk_...

# Hugging Face Inference API token — https://huggingface.co/settings/tokens
# Used for: sentence-transformers/all-MiniLM-L6-v2 (embeddings) + cardiffnlp sentiment
HF_TOKEN=hf_...
